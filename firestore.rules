rules_version='2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection — any authenticated user can read or query (list)
    // Needed for email-based partner lookup from owner accounts
    // Each user can write their own doc; owners can write any user doc
    match /users/{userId} {
      allow read, list: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
                    (request.auth.uid == userId ||
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner');
    }

    // App data — authenticated users can read and write
    // Only owners can delete documents
    match /app_data/{document} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null &&
                    get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner';
    }
  }
}
